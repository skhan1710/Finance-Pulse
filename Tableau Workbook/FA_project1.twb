    <datasource caption='DASHBOARD 1: Financial Performance (Monthly Time Series)' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy)' name='Custom SQL Query' type='text'>WITH monthly AS (&#13;
    SELECT &#13;
        DATE_TRUNC(&apos;month&apos;, txn_date) AS month,&#13;
        SUM(CASE WHEN account_name IN (&apos;Sales Revenue&apos;, &apos;Online Sales&apos;) THEN credit ELSE 0 END) AS revenue,&#13;
        SUM(CASE WHEN account_name = &apos;COGS&apos; THEN debit ELSE 0 END) AS cogs,&#13;
        SUM(CASE WHEN account_name IN (&apos;Payroll Expense&apos;, &apos;Travel Expense&apos;) THEN debit ELSE 0 END) AS operating_expenses&#13;
    FROM general_ledger&#13;
    GROUP BY month&#13;
)&#13;
SELECT &#13;
    month,&#13;
    revenue,&#13;
    cogs,&#13;
    operating_expenses,&#13;
    revenue - cogs AS gross_profit,&#13;
    revenue - cogs - operating_expenses AS net_income,&#13;
    ROUND((revenue - cogs) / NULLIF(revenue, 0) * 100, 2) AS gross_margin_pct,&#13;
    ROUND((revenue - cogs - operating_expenses) / NULLIF(revenue, 0) * 100, 2) AS net_margin_pct,&#13;
    ROUND(&#13;
        (revenue - LAG(revenue) OVER (ORDER BY month)) &#13;
        / NULLIF(LAG(revenue) OVER (ORDER BY month), 0) * 100, 2&#13;
    ) AS revenue_growth_pct,&#13;
    ROUND(&#13;
        AVG(revenue) OVER (ORDER BY month ROWS BETWEEN 3 PRECEDING AND CURRENT ROW), 2&#13;
    ) AS mvg_avg_revenue&#13;
FROM monthly&#13;
ORDER BY month</relation>
