          <datasource-dependencies datasource='federated.1inbru615xzhcu10c6wyz12yxqzr (copy)'>
            <column caption='Trend Arrow_Rev' datatype='string' name='[Calculation_0739468679016448]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF (SUM([revenue]) - LOOKUP(SUM([revenue]), -1)) &gt; 0 THEN &quot;▲&quot;&#13;&#10;ELSEIF (SUM([revenue]) - LOOKUP(SUM([revenue]), -1)) &lt; 0 THEN &quot;▼&quot;&#13;&#10;ELSE &quot;▬&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Hide Old Months' datatype='boolean' name='[Calculation_0739468681003009]' role='measure' type='nominal'>
