    <datasource caption='DASHBOARD 3a: Budget vs Actual Variance (Department + Quarter level)' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy 3)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 3)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 3)' name='Custom SQL Query' type='text'>SELECT &#13;
    fiscal_year, &#13;
    quarter,&#13;
    dept,&#13;
    SUM(budget_usd) AS total_budget,&#13;
    SUM(forecast_usd) AS total_forecast,&#13;
    SUM(actual_usd) AS total_actual,&#13;
    SUM(variance_usd) AS budget_variance,&#13;
    SUM(actual_usd) - SUM(forecast_usd) AS forecast_variance,&#13;
    SUM(forecast_usd) - SUM(budget_usd) AS plan_revision,&#13;
    ROUND(SUM(variance_usd) / NULLIF(SUM(budget_usd), 0) * 100, 2) AS variance_pct_of_budget,&#13;
    ROUND(&#13;
        ABS(SUM(actual_usd) - SUM(budget_usd)) / NULLIF(SUM(budget_usd), 0) * 100, 2&#13;
    ) AS budget_miss_pct,&#13;
    ROUND(&#13;
        ABS(SUM(actual_usd) - SUM(forecast_usd)) / NULLIF(SUM(forecast_usd), 0) * 100, 2&#13;
    ) AS forecast_miss_pct&#13;
FROM budget_forecast&#13;
GROUP BY fiscal_year, quarter, dept&#13;
ORDER BY fiscal_year, quarter, dept</relation>
