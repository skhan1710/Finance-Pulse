                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='&quot;Revenue % Change&quot;' datatype='real' name='[Calculation_0739468681998338]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ABS(SUM([revenue]) - LOOKUP(SUM([revenue]), -1)) / ABS(LOOKUP(SUM([revenue]), -1))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
