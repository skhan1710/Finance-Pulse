      <column caption='top expense ' datatype='string' name='[Calculation_0126216704028673]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF { FIXED [category] : SUM([amount_usd]) } = { MAX({ FIXED [category] : SUM([amount_usd]) }) } THEN [category] END) }' />
      </column>
      <column caption='top_amt_category' datatype='real' name='[Calculation_0126216704479234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX({ FIXED [category] : SUM([amount_usd]) }) }' />
      </column>
      <column caption='flagged_rates' datatype='real' name='[Calculation_0126216717291523]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNTD(IF [flag] != &apos;Normal&apos; THEN [claimid] END) / COUNTD([claimid])) * 100' />
      </column>
      <column caption='arrow_flag' datatype='string' name='[Calculation_0126216722321412]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF (COUNTD(IF [flag] != &apos;Normal&apos; THEN [claimid] END) / COUNTD([claimid])) * 100 &gt; 10 &#13;&#10;THEN &quot;▲ High Risk&quot;&#13;&#10;ELSE &quot;▼ Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_0689991255236615]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Normal Curve' datatype='real' name='[Calculation_0955797528035333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(COUNT([claimid])) * 0.25 * &#13;&#10;(1 / (SQRT(2 * PI()))) * &#13;&#10;EXP(-0.5 * (POWER(AVG([z_score]), 2)))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Custom SQL Query' datatype='table' name='[__tableau_internal_object_id__].[_3200BDB01BAF4CE782282077697187AD]' role='measure' type='quantitative' />
      <column datatype='real' name='[amount_usd]' role='measure' type='quantitative' />
      <column datatype='string' name='[category]' role='dimension' type='nominal' />
      <column datatype='string' name='[flag]' role='dimension' type='nominal' />
      <column aggregation='None' caption='z_score (bin)' datatype='integer' name='[z_score (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-2' formula='[z_score]' peg='0' size='0.25' />
      </column>
      <column datatype='real' name='[z_score]' role='measure' type='quantitative' />
      <column-instance column='[amount_usd]' derivation='None' name='[none:amount_usd:ok]' pivot='key' type='ordinal' />
      <column-instance column='[category]' derivation='None' name='[none:category:nk]' pivot='key' type='nominal' />
      <column-instance column='[flag]' derivation='None' name='[none:flag:nk]' pivot='key' type='nominal' />
      <column-instance column='[z_score]' derivation='None' name='[none:z_score:ok]' pivot='key' type='ordinal' />
      <group caption='Action (amount_usd,category,flag,z_score)' hidden='true' name='[Action (amount_usd,category,flag,z_score)]' name-style='unqualified' user:auto-column='sheet_link'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[none:amount_usd:ok]' />
          <groupfilter function='level-members' level='[category]' />
          <groupfilter function='level-members' level='[flag]' />
          <groupfilter function='level-members' level='[none:z_score:ok]' />
        </groupfilter>
      </group>
      <group caption='Action (category)' hidden='true' name='[Action (category)]' name-style='unqualified' user:auto-column='sheet_link'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[category]' />
        </groupfilter>
      </group>
      <group caption='Action (category,flag)' hidden='true' name='[Action (category,flag)]' name-style='unqualified' user:auto-column='sheet_link'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[category]' />
          <groupfilter function='level-members' level='[flag]' />
        </groupfilter>
      </group>
      <group caption='Action (flag,z_score (bin))' hidden='true' name='[Action (flag,z_score (bin))]' name-style='unqualified' user:auto-column='sheet_link'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[flag]' />
          <groupfilter function='level-members' level='[z_score (bin)]' />
        </groupfilter>
      </group>
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:flag:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>%many-values%</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;Normal&quot;</bucket>
            </map>
