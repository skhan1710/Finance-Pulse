    <datasource caption='DASHBOARD 3c: Budget vs Actual Variance (Department + Monthly level)' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy 12)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 12)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 12)' name='Custom SQL Query' type='text'>WITH gl_monthly AS (&#13;
    SELECT &#13;
        DATE_TRUNC(&apos;month&apos;, txn_date) AS month,&#13;
        EXTRACT(YEAR FROM txn_date)::INTEGER AS fiscal_year,&#13;
        EXTRACT(QUARTER FROM txn_date)::INTEGER AS quarter,&#13;
        SUM(debit) AS actual_spending&#13;
    FROM general_ledger&#13;
    WHERE account_name IN (&apos;COGS&apos;, &apos;Payroll Expense&apos;, &apos;Travel Expense&apos;)&#13;
    GROUP BY month, fiscal_year, quarter&#13;
),&#13;
budget_monthly AS (&#13;
    SELECT &#13;
        fiscal_year::INTEGER,&#13;
        quarter,&#13;
        ROUND(SUM(budget_usd) / 3, 2) AS monthly_budget&#13;
    FROM budget_forecast&#13;
    GROUP BY fiscal_year, quarter&#13;
)&#13;
SELECT &#13;
    g.month,&#13;
    g.actual_spending,&#13;
    b.monthly_budget,&#13;
    g.actual_spending - b.monthly_budget AS variance,&#13;
    ROUND((g.actual_spending - b.monthly_budget) / b.monthly_budget * 100, 2) AS variance_pct&#13;
FROM gl_monthly g&#13;
JOIN budget_monthly b &#13;
    ON g.fiscal_year = b.fiscal_year&#13;
    AND g.quarter = b.quarter&#13;
ORDER BY month</relation>
        <metadata-records>
          <metadata-record class='column'>
            <remote-name>month</remote-name>
