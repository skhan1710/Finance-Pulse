              <aliases>
                <alias key='&quot;base_case&quot;' value='Base Case' />
                <alias key='&quot;fx_down_10pct&quot;' value='-10% FX' />
                <alias key='&quot;fx_down_5pct&quot;' value='-5% FX' />
                <alias key='&quot;fx_up_10pct&quot;' value='+10% FX' />
                <alias key='&quot;fx_up_5pct&quot;' value='+5% FX' />
