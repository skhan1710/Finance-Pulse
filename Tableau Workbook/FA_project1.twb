    <datasource caption='DASHBOARD 2: Department Profitability' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy 2)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 2)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 2)' name='Custom SQL Query' type='text'>WITH revenue AS (&#13;
    SELECT dept, &#13;
        DATE_TRUNC(&apos;month&apos;, txn_date) AS month,&#13;
        SUM(credit) AS total_revenue&#13;
    FROM general_ledger&#13;
    WHERE account_name IN (&apos;Sales Revenue&apos;, &apos;Online Sales&apos;)&#13;
    GROUP BY dept, month&#13;
),&#13;
cogs AS (&#13;
    SELECT dept,&#13;
        DATE_TRUNC(&apos;month&apos;, txn_date) AS month,&#13;
        SUM(debit) AS cogs&#13;
    FROM general_ledger&#13;
    WHERE account_name = &apos;COGS&apos;&#13;
    GROUP BY dept, month&#13;
),&#13;
operating_expenses AS (&#13;
    SELECT dept,&#13;
        DATE_TRUNC(&apos;month&apos;, txn_date) AS month,&#13;
        SUM(debit) AS total_exp&#13;
    FROM general_ledger&#13;
    WHERE account_name IN (&apos;Payroll Expense&apos;, &apos;Travel Expense&apos;)&#13;
    GROUP BY dept, month&#13;
),&#13;
wide AS (&#13;
    SELECT &#13;
        revenue.dept,&#13;
        revenue.month,&#13;
        revenue.total_revenue, &#13;
        cogs.cogs, &#13;
        (revenue.total_revenue - cogs.cogs) AS gross_profit,&#13;
        operating_expenses.total_exp AS operating_expenses,&#13;
        (revenue.total_revenue - cogs.cogs - operating_expenses.total_exp) AS net_income&#13;
    FROM revenue&#13;
    JOIN cogs ON revenue.dept = cogs.dept AND revenue.month = cogs.month&#13;
    JOIN operating_expenses ON revenue.dept = operating_expenses.dept AND revenue.month = operating_expenses.month&#13;
)&#13;
SELECT dept, month, &apos;Revenue&apos; AS component, total_revenue AS amount FROM wide&#13;
UNION ALL&#13;
SELECT dept, month, &apos;COGS&apos;, cogs FROM wide&#13;
UNION ALL&#13;
SELECT dept, month, &apos;Gross Profit&apos;, gross_profit FROM wide&#13;
UNION ALL&#13;
SELECT dept, month, &apos;Operating Expenses&apos;, operating_expenses FROM wide&#13;
UNION ALL&#13;
SELECT dept, month, &apos;Net Income&apos;, net_income FROM wide&#13;
ORDER BY dept, month, component</relation>
