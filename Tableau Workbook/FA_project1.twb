        <calculation class='tableau' formula='IF (SUM([net_income]) - LOOKUP(SUM([net_income]), -1)) &gt; 0 THEN &quot;▲&quot;&#13;&#10;ELSEIF (SUM([net_income]) - LOOKUP(SUM([net_income]), -1)) &lt; 0 THEN &quot;▼&quot;&#13;&#10;ELSE &quot;▬&quot;&#13;&#10;END'>
