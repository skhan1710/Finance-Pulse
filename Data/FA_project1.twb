    <datasource caption='DASHBOARD 5c: Expense Anomaly Detection (Z-Score with Flags)' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy 10)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 10)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 10)' name='Custom SQL Query' type='text'>WITH fx_rates AS (&#13;
    SELECT &apos;USD&apos; AS currency, 1.00 AS rate&#13;
    UNION ALL SELECT &apos;EUR&apos;, 1.08&#13;
    UNION ALL SELECT &apos;GBP&apos;, 1.27&#13;
    UNION ALL SELECT &apos;CAD&apos;, 0.74&#13;
    UNION ALL SELECT &apos;AUD&apos;, 0.65&#13;
),&#13;
z_scores AS (&#13;
    SELECT claimid, employeeid, category, &#13;
        ROUND(amount * rate, 2) AS amount_usd,&#13;
        approved_by, submit_date,&#13;
        ROUND((amount * rate - AVG(amount * rate) OVER (PARTITION BY category)) &#13;
        / STDDEV(amount * rate) OVER (PARTITION BY category), 3) AS z_score&#13;
    FROM expense_claims&#13;
    JOIN fx_rates ON fx_rates.currency = expense_claims.currency&#13;
)&#13;
SELECT claimid, employeeid, approved_by, category, amount_usd, submit_date, z_score,&#13;
    CASE &#13;
        WHEN ABS(z_score) &gt;&gt; 2 THEN &apos;Investigate&apos;&#13;
        WHEN ABS(z_score) &gt;&gt; 1 THEN &apos;Unusual&apos;&#13;
        ELSE &apos;Normal&apos;&#13;
    END AS flag&#13;
FROM z_scores&#13;
ORDER BY ABS(z_score) DESC</relation>
