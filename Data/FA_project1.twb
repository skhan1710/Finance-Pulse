        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 6)' name='Custom SQL Query' type='text'>SELECT &#13;
    &apos;AR&apos; AS type,&#13;
    customer AS entity, &#13;
    ROUND(SUM(amount) / SUM(SUM(amount)) OVER () * 100, 2) AS pct_of_total&#13;
FROM ar&#13;
WHERE status IN (&apos;Open&apos;, &apos;Partial&apos;)&#13;
GROUP BY customer&#13;
&#13;
UNION ALL&#13;
&#13;
SELECT &#13;
    &apos;AP&apos; AS type,&#13;
    vendor AS entity, &#13;
    ROUND(SUM(amount) / SUM(SUM(amount)) OVER () * 100, 2) AS pct_of_total&#13;
FROM ap&#13;
WHERE status IN (&apos;Open&apos;, &apos;Partial&apos;)&#13;
GROUP BY vendor&#13;
ORDER BY type, pct_of_total DESC</relation>
