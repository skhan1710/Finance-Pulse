      <aliases enabled='yes' />
      <column caption='Normal Curve' datatype='real' name='[Calculation_0955797528035333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(COUNT([claimid])) * 0.25 * &#13;&#10;(1 / (SQRT(2 * PI()))) * &#13;&#10;EXP(-0.5 * (POWER(AVG([z_score]), 2)))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Custom SQL Query' datatype='table' name='[__tableau_internal_object_id__].[_3200BDB01BAF4CE782282077697187AD]' role='measure' type='quantitative' />
      <column datatype='string' name='[category]' role='dimension' type='nominal' />
      <column datatype='string' name='[flag]' role='dimension' type='nominal' />
      <column aggregation='None' caption='z_score (bin)' datatype='integer' name='[z_score (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-2' formula='[z_score]' peg='0' size='0.25' />
      </column>
      <column datatype='real' name='[z_score]' role='measure' type='quantitative' />
      <column-instance column='[category]' derivation='None' name='[none:category:nk]' pivot='key' type='nominal' />
      <column-instance column='[flag]' derivation='None' name='[none:flag:nk]' pivot='key' type='nominal' />
      <group caption='Action (flag,z_score (bin))' hidden='true' name='[Action (flag,z_score (bin))]' name-style='unqualified' user:auto-column='sheet_link'>
        <groupfilter function='crossjoin'>
          <groupfilter function='level-members' level='[flag]' />
          <groupfilter function='level-members' level='[z_score (bin)]' />
        </groupfilter>
      </group>
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:flag:nk]' type='palette'>
            <map to='#59a14f'>
              <bucket>&quot;Normal&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Investigate&quot;</bucket>
            </map>
            <map to='#edc948'>
              <bucket>&quot;Unusual&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='shape' field='[none:category:nk]' type='shape'>
            <map to='asterisk'>
              <bucket>&quot;Travel&quot;</bucket>
            </map>
            <map to='circle'>
              <bucket>&quot;Entertainment&quot;</bucket>
            </map>
            <map to='plus'>
              <bucket>&quot;Supplies&quot;</bucket>
            </map>
            <map to='square'>
              <bucket>&quot;Meals&quot;</bucket>
            </map>
            <map to='times'>
              <bucket>&quot;Training&quot;</bucket>
            </map>
          </encoding>
        </style-rule>
      </style>
      <semantic-values>
        <semantic-value key='[Country].[Name]' value='&quot;United States&quot;' />
      </semantic-values>
      <object-graph>
        <objects>
          <object caption='Custom SQL Query' id='_3200BDB01BAF4CE782282077697187AD'>
            <properties context=''>
              <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 10)' name='Custom SQL Query' type='text'>WITH fx_rates AS (&#13;
    SELECT &apos;USD&apos; AS currency, 1.00 AS rate&#13;
    UNION ALL SELECT &apos;EUR&apos;, 1.08&#13;
    UNION ALL SELECT &apos;GBP&apos;, 1.27&#13;
    UNION ALL SELECT &apos;CAD&apos;, 0.74&#13;
    UNION ALL SELECT &apos;AUD&apos;, 0.65&#13;
),&#13;
z_scores AS (&#13;
    SELECT claimid, employeeid, category, &#13;
        ROUND(amount * rate, 2) AS amount_usd,&#13;
        approved_by, submit_date,&#13;
        ROUND((amount * rate - AVG(amount * rate) OVER (PARTITION BY category)) &#13;
        / STDDEV(amount * rate) OVER (PARTITION BY category), 3) AS z_score&#13;
    FROM expense_claims&#13;
    JOIN fx_rates ON fx_rates.currency = expense_claims.currency&#13;
)&#13;
SELECT claimid, employeeid, approved_by, category, amount_usd, submit_date, z_score,&#13;
    CASE &#13;
        WHEN ABS(z_score) &gt;&gt; 2 THEN &apos;Investigate&apos;&#13;
        WHEN ABS(z_score) &gt;&gt; 1 THEN &apos;Unusual&apos;&#13;
        ELSE &apos;Normal&apos;&#13;
    END AS flag&#13;
FROM z_scores&#13;
ORDER BY ABS(z_score) DESC</relation>
            </properties>
          </object>
        </objects>
      </object-graph>
    </datasource>
    <datasource caption='DASHBOARD 5d: FX Exposure Summary' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy 11)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 11)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 11)' name='Custom SQL Query' type='text'>WITH fx_rates AS (&#13;
    SELECT &apos;USD&apos; AS currency, 1.00 AS rate&#13;
    UNION ALL SELECT &apos;EUR&apos;, 1.08&#13;
    UNION ALL SELECT &apos;GBP&apos;, 1.27&#13;
    UNION ALL SELECT &apos;CAD&apos;, 0.74&#13;
    UNION ALL SELECT &apos;AUD&apos;, 0.65&#13;
)&#13;
SELECT &#13;
    ROUND(SUM(CASE WHEN expense_claims.currency = &apos;USD&apos; THEN amount ELSE 0 END), 2) AS usd_expenses,&#13;
    ROUND(SUM(CASE WHEN expense_claims.currency != &apos;USD&apos; THEN amount * rate ELSE 0 END), 2) AS non_usd_expenses,&#13;
    ROUND(SUM(amount * rate), 2) AS total_expenses,&#13;
    ROUND(SUM(CASE WHEN expense_claims.currency != &apos;USD&apos; THEN amount * rate ELSE 0 END) / SUM(amount * rate) * 100, 2) AS pct_fx_exposed&#13;
FROM expense_claims&#13;
JOIN fx_rates ON fx_rates.currency = expense_claims.currency</relation>
