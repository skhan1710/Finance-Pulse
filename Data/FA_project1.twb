    <datasource caption='DASHBOARD 5a: Expense Category Spending + FX Scenario Analysis' inline='true' name='federated.1inbru615xzhcu10c6wyz12yxqzr (copy 9)' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 9)'>
            <connection authentication='username-password' class='postgres' dbname='FA_Project' one-time-sql='' port='1710' server='localhost' username='postgres' />
          </named-connection>
        </named-connections>
        <relation connection='postgres.0jhzr4j1wzq8ei18trvir0mnkdup (copy 9)' name='Custom SQL Query' type='text'>WITH fx_rates AS (&#13;
    SELECT &apos;USD&apos; AS currency, 1.00 AS rate&#13;
    UNION ALL SELECT &apos;EUR&apos;, 1.08&#13;
    UNION ALL SELECT &apos;GBP&apos;, 1.27&#13;
    UNION ALL SELECT &apos;CAD&apos;, 0.74&#13;
    UNION ALL SELECT &apos;AUD&apos;, 0.65&#13;
)&#13;
SELECT category,&#13;
    COUNT(*) AS claim_count,&#13;
    ROUND(AVG(amount * rate), 2) AS avg_claim_usd,&#13;
    ROUND(SUM(CASE &#13;
        WHEN expense_claims.currency = &apos;USD&apos; THEN amount &#13;
        ELSE amount * rate * 0.90 &#13;
    END), 2) AS fx_down_10pct,&#13;
    ROUND(SUM(CASE &#13;
        WHEN expense_claims.currency = &apos;USD&apos; THEN amount &#13;
        ELSE amount * rate * 0.95 &#13;
    END), 2) AS fx_down_5pct,&#13;
    ROUND(SUM(amount * rate), 2) AS base_case,&#13;
    ROUND(SUM(CASE &#13;
        WHEN expense_claims.currency = &apos;USD&apos; THEN amount &#13;
        ELSE amount * rate * 1.05 &#13;
    END), 2) AS fx_up_5pct,&#13;
    ROUND(SUM(CASE &#13;
        WHEN expense_claims.currency = &apos;USD&apos; THEN amount &#13;
        ELSE amount * rate * 1.10 &#13;
    END), 2) AS fx_up_10pct&#13;
FROM expense_claims&#13;
JOIN fx_rates ON fx_rates.currency = expense_claims.currency&#13;
GROUP BY category&#13;
ORDER BY base_case DESC</relation>
        <metadata-records>
          <metadata-record class='column'>
            <remote-name>category</remote-name>
